From 6f0cacc08d7582f1b02ba259e48144df10e96fa7 Mon Sep 17 00:00:00 2001
From: dpi <pro@danielph.in>
Date: Thu, 5 Mar 2026 12:59:37 +0800
Subject: [PATCH] rename 'prompt' key to 'oidc_prompt', slight refactor in
 getUrlOptions, use config factory directly in case plugin is removed or
 broken. entity api shouldnt be used in .install

---
 config/schema/openid_connect.schema.yml |  2 +-
 openid_connect.install                  | 50 ++++++++++++++++++-------
 src/Plugin/OpenIDConnectClientBase.php  | 20 +++++-----
 3 files changed, 47 insertions(+), 25 deletions(-)

diff --git a/config/schema/openid_connect.schema.yml b/config/schema/openid_connect.schema.yml
index 70f4279..f3c5a5f 100644
--- a/config/schema/openid_connect.schema.yml
+++ b/config/schema/openid_connect.schema.yml
@@ -68,7 +68,7 @@ openid_connect.client.plugin.*:
     iss_allowed_domains:
       type: string
       label: 'Domains that are allowed to initiate SSO using ISS'
-    prompt:
+    oidc_prompt:
       type: sequence
       label: 'Prompt'
       sequence:
diff --git a/openid_connect.install b/openid_connect.install
index 83b5702..773939a 100644
--- a/openid_connect.install
+++ b/openid_connect.install
@@ -416,23 +416,47 @@ function openid_connect_update_30004() {
 }
 
 /**
- * Update all plugins to use the 'login' prompt.
+ * Removed 'prompt' plugin config migration.
  */
 function openid_connect_update_30005() {
-  $definitions = \Drupal::service('plugin.manager.openid_connect_client')->getDefinitions();
+  // Replaced by openid_connect_update_30006().
+}
 
-  foreach ($definitions as $plugin) {
-    /** @var \Drupal\openid_connect\OpenIDConnectClientEntityInterface[] $clients */
-    $clients = \Drupal::entityTypeManager()
-      ->getStorage('openid_connect_client')
-      ->loadByProperties(['plugin' => $plugin['id']]);
 
-    foreach ($clients as $client) {
-      $config = $client->getPlugin()->getConfiguration();
-      $config['prompt'] = ['login' => 'login'];
-      $client->getPlugin()->setConfiguration($config);
-      $client->save();
+/**
+ * Update all plugins to use the 'login' prompt.
+ */
+function openid_connect_update_30006(): TranslatableMarkup {
+  $configFactory = \Drupal::configFactory();
+  $updatedConfigNames = [];
+  foreach ($configFactory->listAll('openid_connect.client.') as $configName) {
+    $config = $configFactory->getEditable($configName);
+    $settings = $config->get('settings');
+    $prompt = $settings['prompt'] ?? NULL;
+    // If the old openid_connect_update_30005 ran successfully, this will be a
+    // non-empty array. It could have also been updated since that run, so
+    // migrate that value across.
+    // Otherwise, if it doesn't exist, its probably because 30005 didn't run, or
+    // the plugin doesn't have a 'prompt' key.
+    $configLooksLike30005 = (is_array($prompt) && $prompt !== []);
+    $newOidcPromptValue = $configLooksLike30005
+      ? $prompt
+      : ['login' => 'login'];
+
+    // Only remove if it looks like ours, custom 'prompt' values shall be
+    // retained.
+    if ($configLooksLike30005) {
+      unset($settings['prompt']);
     }
+
+    $config
+      ->set('settings', $settings + [
+          // In any case, we need to add this new value to all configs:
+        'oidc_prompt' => $newOidcPromptValue,
+      ])
+      ->save(TRUE);
+    $updatedConfigNames[] = $configName;
   }
-  \Drupal::messenger()->addWarning(t('The OpenID Connect module settings have been updated. Administrators should review the OpenID Connect configuration, particularly the prompt settings for all enabled providers.'));
+
+  return new TranslatableMarkup('OpenID Connect client plugins updated: @plugins', ['@plugins' => implode(', ', $updatedConfigNames)]);
 }
diff --git a/src/Plugin/OpenIDConnectClientBase.php b/src/Plugin/OpenIDConnectClientBase.php
index 9c8193c..daffc14 100644
--- a/src/Plugin/OpenIDConnectClientBase.php
+++ b/src/Plugin/OpenIDConnectClientBase.php
@@ -199,7 +199,7 @@ abstract class OpenIDConnectClientBase extends PluginBase implements OpenIDConne
       'client_id' => '',
       'client_secret' => '',
       'iss_allowed_domains' => '',
-      'prompt' => ['login' => 'login'],
+      'oidc_prompt' => ['login' => 'login'],
     ];
   }
 
@@ -246,7 +246,7 @@ abstract class OpenIDConnectClientBase extends PluginBase implements OpenIDConne
       '#type' => 'textarea',
       '#default_value' => $this->configuration['iss_allowed_domains'],
     ];
-    $form['prompt'] = [
+    $form['oidc_prompt'] = [
       '#title' => $this->t('Prompt'),
       '#type' => 'checkboxes',
       '#options' => [
@@ -255,7 +255,7 @@ abstract class OpenIDConnectClientBase extends PluginBase implements OpenIDConne
         'consent' => $this->t('Consent'),
         'select_account' => $this->t('Select account'),
       ],
-      '#default_value' => array_filter(array_values($this->configuration['prompt'] ?? [])),
+      '#default_value' => array_filter(array_values($this->configuration['oidc_prompt'] ?? [])),
       '#description' => $this->t('<strong><em>Please note:</em> This option has security implications.</strong><br />While valid, not selecting a prompt could lead to security issues and is discouraged in most use cases.'),
     ];
     return $form;
@@ -275,10 +275,10 @@ abstract class OpenIDConnectClientBase extends PluginBase implements OpenIDConne
     $configuration = $form_state->getValues();
 
     // Validate that 'none' prompt is not selected with other values.
-    if (isset($configuration['prompt']) && is_array($configuration['prompt'])) {
-      $prompt_values = array_filter($configuration['prompt']);
+    if (isset($configuration['oidc_prompt']) && is_array($configuration['oidc_prompt'])) {
+      $prompt_values = array_filter($configuration['oidc_prompt']);
       if (isset($prompt_values['none']) && count($prompt_values) > 1) {
-        $form_state->setErrorByName('prompt', $this->t('The "None" option cannot be selected with other values.'));
+        $form_state->setErrorByName('oidc_prompt', $this->t('The "None" option cannot be selected with other values.'));
       }
     }
   }
@@ -339,11 +339,9 @@ abstract class OpenIDConnectClientBase extends PluginBase implements OpenIDConne
     ];
 
     // The prompt is optional. Only include it if settings are available.
-    if (
-      isset($this->configuration['prompt']) &&
-      count($this->configuration['prompt']) > 0
-    ) {
-      $return['query']['prompt'] = implode(' ', array_filter($this->configuration['prompt']));
+    $prompt = \array_filter($this->configuration['oidc_prompt'] ?? []);
+    if ($prompt !== []) {
+      $return['query']['prompt'] = \implode(' ', $prompt);
     }
     return $return;
   }
